# more backend environment variables
# Copy this file to `.env` (same directory) and fill in the blanks. The app
# reads these at process startup; uvicorn --env-file=.env is recommended.

# --- LLM provider -----------------------------------------------------------
# Your OpenAI-compatible upstream. LiteLLM routes requests through this.
# Typical values:
#   - OpenAI direct:      https://api.openai.com/v1
#   - DeepSeek:           https://api.deepseek.com/v1
#   - Azure OpenAI:       https://<resource>.openai.azure.com
#   - local Ollama:       http://localhost:11434/v1
MORE_LLM_BASE_URL=
MORE_LLM_API_KEY=
MORE_LLM_MODEL=deepseek-chat
MORE_LLM_TIMEOUT=60

# --- Langfuse self-hosted observability (optional) --------------------------
# OFF BY DEFAULT. Enable only when you also:
#   1. Start the Langfuse stack:
#        docker compose -f ../docker-compose.langfuse.yml up -d
#   2. Install the optional extra into the backend virtualenv:
#        pip install -e ".[observability]"
#   3. Create a project in the Langfuse UI (http://localhost:3000) and copy
#      the project's public/secret keys into the two slots below.
#
# If either key is blank, the `observe` decorators in
# `app/observability_langfuse.py` stay as no-ops: zero overhead, no network,
# no dependency on the optional package. Safe to commit the blank version.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
